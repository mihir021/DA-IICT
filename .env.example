# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=grocery_admin

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_PORT=8000

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:63342
FRONTEND_ORIGINS=http://localhost:63342,http://127.0.0.1:63342,http://localhost:5500,http://127.0.0.1:5500

# Admin bootstrap
ADMIN_BOOTSTRAP_NAME=Store Manager
ADMIN_BOOTSTRAP_EMAIL=admin@grocerypulse.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

# Optional integrations for later phases
OPENAI_API_KEY=<optional>
OPENAI_MODEL=gpt-4o-mini
REDIS_URL=redis://localhost:6379/0
EMAIL_USER=<optional>
EMAIL_PASS=<optional>
GOOGLE_CLIENT_ID=<optional>
GOOGLE_CLIENT_SECRET=<optional>

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLICKSTREAM_TOPIC=user-events
KAFKA_COMPETITOR_TOPIC=competitor-prices
